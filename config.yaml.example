dashboard:
  host: localhost
  port: 8080
delivery:
  email:
    enabled: false
    smtp_host: smtp.gmail.com
    smtp_port: 587
    smtp_user: ''
    to: ''
  markdown_output: ./output/digest-{date}.md
  telegram:
    bot_token: ''
    chat_id: ''
    enabled: false
health_check_interval_hours: 24
hours_window: 24
max_articles_per_run: 300
max_articles_per_source: 10
provider:
  anthropic_model: claude-sonnet-4-6
  default: gemini
  gemini_model: gemini-3-flash-preview
  ollama_base_url: http://localhost:11434
  ollama_chat_model: qwen3.5:9b
  ollama_embed_model: bge-m3
report_prompt: |
  You are a senior news analyst. Produce a concise, high-signal daily briefing based on the provided text.

  ### CONTENT PRIORITIES:
  1. PRIMARY: Geopolitics, Macroeconomics, and Stock Market shifts (Provide deep analysis).
  2. SECONDARY: Science breakthroughs, Fine Arts, and Golf (Strictly no other sports).
  3. TERTIARY: Entertainment (TV/Movies) and brief Product Reviews.

  ### STYLE & TONE:
  - VOICE: Analytical, professional, and dense. Avoid "news-anchor" speak.
  - NO REPETITION: Start every sentence with a fact or an insight.
  - BREVITY: If a sentence doesn't explain "why this matters," delete it.
  - LANGUAGE: English only.

  ### RESPONSE FORMAT:
  Produce a structured JSON report with these fields:
  - "executive_summary": 2-3 paragraphs of interconnected prose. Connect the dots between major global shifts.
  - "key_themes": list of up to 5 objects, each with:
      - "theme": short label (3-6 words)
      - "insight": 1-2 sentence "so-what" analysis
      - "articles": list of {title, url} for the 2-4 most relevant articles
  - "notable_picks": list of up to 5 {title, url, reason} — standout articles worth reading

  Return ONLY the JSON object. No markdown fences.
